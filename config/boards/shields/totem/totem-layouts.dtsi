/*
 * Copyright (c) 2022 The ZMK Contributors
 * SPDX-License-Identifier: MIT
 *
 * Physical layout for the TOTEM 38-key split keyboard.
 *
 * Key positions are derived from the authoritative QMK keyboard.json at:
 *   GEIGEIGEIST/TOTEM/firmware/QMK/VIAL_source/totem/keyboard.json
 * converted from QMK key-units to ZMK centiunits (multiply by 100).
 *
 * Key order matches the matrix transform map exactly:
 *   Row 0  : RC(0,0)–RC(0,9)   — top row, left then right
 *   Row 1  : RC(1,0)–RC(1,9)   — home row, left then right
 *   Row 2  : RC(3,0) RC(2,0)–RC(2,9) RC(3,9) — bottom row incl. outer pinky keys
 *   Thumbs : RC(3,2)–RC(3,7)   — thumb cluster, left then right
 *
 * Include this file from any shield overlay or dtsi that needs the physical
 * layout (both the main halves via totem.dtsi and the dongle overlay).
 */

#include <physical_layouts.dtsi>

/ {
    totem_layout: layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "TOTEM";
        transform = <&default_transform>;

        keys = <
            /* RC(0,0) L00 */ &key_physical_attrs 100 100  100 140 0 0 0
            /* RC(0,1) L01 */ &key_physical_attrs 100 100  200  60 0 0 0
            /* RC(0,2) L02 */ &key_physical_attrs 100 100  300   0 0 0 0
            /* RC(0,3) L03 */ &key_physical_attrs 100 100  400  50 0 0 0
            /* RC(0,4) L04 */ &key_physical_attrs 100 100  500  65 0 0 0
            /* RC(0,5) R00 */ &key_physical_attrs 100 100  900  65 0 0 0
            /* RC(0,6) R01 */ &key_physical_attrs 100 100 1000  50 0 0 0
            /* RC(0,7) R02 */ &key_physical_attrs 100 100 1100   0 0 0 0
            /* RC(0,8) R03 */ &key_physical_attrs 100 100 1200  60 0 0 0
            /* RC(0,9) R04 */ &key_physical_attrs 100 100 1300 140 0 0 0
            /* RC(1,0) L10 */ &key_physical_attrs 100 100  100 240 0 0 0
            /* RC(1,1) L11 */ &key_physical_attrs 100 100  200 160 0 0 0
            /* RC(1,2) L12 */ &key_physical_attrs 100 100  300 100 0 0 0
            /* RC(1,3) L13 */ &key_physical_attrs 100 100  400 150 0 0 0
            /* RC(1,4) L14 */ &key_physical_attrs 100 100  500 165 0 0 0
            /* RC(1,5) R10 */ &key_physical_attrs 100 100  900 165 0 0 0
            /* RC(1,6) R11 */ &key_physical_attrs 100 100 1000 150 0 0 0
            /* RC(1,7) R12 */ &key_physical_attrs 100 100 1100 100 0 0 0
            /* RC(1,8) R13 */ &key_physical_attrs 100 100 1200 160 0 0 0
            /* RC(1,9) R14 */ &key_physical_attrs 100 100 1300 240 0 0 0
            /* RC(3,0) L30 */ &key_physical_attrs 100 100    0 290 0 0 0
            /* RC(2,0) L20 */ &key_physical_attrs 100 100  100 340 0 0 0
            /* RC(2,1) L21 */ &key_physical_attrs 100 100  200 260 0 0 0
            /* RC(2,2) L22 */ &key_physical_attrs 100 100  300 200 0 0 0
            /* RC(2,3) L23 */ &key_physical_attrs 100 100  400 250 0 0 0
            /* RC(2,4) L24 */ &key_physical_attrs 100 100  500 265 0 0 0
            /* RC(2,5) R20 */ &key_physical_attrs 100 100  900 265 0 0 0
            /* RC(2,6) R21 */ &key_physical_attrs 100 100 1000 250 0 0 0
            /* RC(2,7) R22 */ &key_physical_attrs 100 100 1100 200 0 0 0
            /* RC(2,8) R23 */ &key_physical_attrs 100 100 1200 260 0 0 0
            /* RC(2,9) R24 */ &key_physical_attrs 100 100 1300 340 0 0 0
            /* RC(3,9) R34 */ &key_physical_attrs 100 100 1400 290 0 0 0
            /* RC(3,2) L32 */ &key_physical_attrs 100 100  360 350 0 0 0
            /* RC(3,3) L33 */ &key_physical_attrs 100 100  480 365 0 0 0
            /* RC(3,4) L34 */ &key_physical_attrs 100 100  600 385 0 0 0
            /* RC(3,5) R30 */ &key_physical_attrs 100 100  800 385 0 0 0
            /* RC(3,6) R31 */ &key_physical_attrs 100 100  920 365 0 0 0
            /* RC(3,7) R32 */ &key_physical_attrs 100 100 1040 350 0 0 0
        >;
    };
};
