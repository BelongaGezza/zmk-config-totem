/*
 * Copyright (c) 2022 The ZMK Contributors
 * SPDX-License-Identifier: MIT
 *
 * totem_dongle — central shield for the Makerdiary nRF52840 MDK USB Dongle.
 *
 * The dongle has no keys of its own.  It acts as the BLE split central,
 * aggregating key events from totem_left_peripheral and totem_right, and
 * forwarding them to the host as USB HID.
 *
 * We deliberately do NOT include totem.dtsi here because that file references
 * &xiao_d GPIO aliases that do not exist on this board.  Instead we reproduce
 * the matrix transform and substitute a mock kscan.
 *
 * LED GPIO assignments and flash partition layout come directly from the
 * Makerdiary board DTS (nrf52840_mdk_usb_dongle_nrf52840_zmk.dts) — no
 * overrides needed here.
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include "totem-layouts.dtsi"

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &totem_layout;
    };

    /*
     * Full 38-key Totem matrix transform — must match the layout known by the
     * peripherals so that key-position combos resolve correctly on the central.
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;
//             | SW01  | SW02  | SW03  | SW04  | SW05  |  | SW05  | SW04  | SW03  | SW02  | SW01  |
//             | SW06  | SW07  | SW08  | SW09  | SW10  |  | SW10  | SW09  | SW08  | SW07  | SW06  |
//      | SW16 | SW11  | SW12  | SW13  | SW14  | SW15  |  | SW15  | SW14  | SW13  | SW12  | SW11  | SW16  |
//                             | SW17  | SW18  | SW19  |  | SW19  | SW18  | SW17  |
        map = <
                RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)    RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
                RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)    RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
        RC(3,0) RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)    RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(3,9)
                                RC(3,2) RC(3,3) RC(3,4)    RC(3,5) RC(3,6) RC(3,7)
        >;
    };

    /* No physical keys on the dongle — mock scanner produces no events. */
    kscan0: kscan_0 {
        compatible = "zmk,kscan-mock";
        events = <>;
    };
};
